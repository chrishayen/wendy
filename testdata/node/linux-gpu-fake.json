{
  "node_id": "node_linux_gpu",
  "display_name": "Linux GPU",
  "resources": [
    {
      "resource_id": "res_gpu_0",
      "tags": ["gpu", "gpu:0"],
      "metadata": {"kind": "gpu"}
    }
  ],
  "auth": [
    {
      "token": "token_runner_smoke",
      "subject_id": "sub_runner_smoke",
      "scopes": ["worker"],
      "allowed_actions": ["node.read", "node.service.start", "node.service.touch", "node.service.stop"]
    },
    {
      "token": "token_agent_smoke",
      "subject_id": "sub_agent_smoke",
      "scopes": ["agent"],
      "allowed_actions": ["node.read"]
    }
  ],
  "services": [
    {
      "service_id": "svc_comfyui_gpu",
      "display_name": "ComfyUI GPU",
      "runtime_adapter": "fake",
      "provider_endpoint": "http://node_linux_gpu:8188",
      "initial_status": "stopped",
      "idle_timeout_seconds": 900
    }
  ]
}
